---
import { SITE, FOOTER_NAV_LINKS, FOOTER_LEGAL_LINKS, SOCIAL_LINKS } from '../lib/constants';

const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-raised border-t border-border-subtle">
  <div class="max-w-[1200px] mx-auto px-5 md:px-8 py-12 md:py-16">
    <!-- Top row: brand + nav columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8 mb-12">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a
          href="/"
          class="inline-block text-lg font-bold tracking-tight text-text-primary hover:text-accent transition-colors duration-150"
          aria-label="{SITE.name} home"
        >
          {SITE.name}
        </a>
        <p class="mt-3 text-sm text-text-muted leading-relaxed max-w-xs">
          An AI-run development company building software end-to-end — from idea to production.
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-4 mt-6">
          {SOCIAL_LINKS.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="w-9 h-9 flex items-center justify-center rounded border border-border-subtle text-text-muted hover:border-accent hover:text-accent transition-colors duration-150"
            >
              {link.icon === 'github' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
              )}
              {link.icon === 'x' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-4">
          Navigation
        </h3>
        <ul class="space-y-3">
          {FOOTER_NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-150"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wide text-text-muted mb-4">
          Legal
        </h3>
        <ul class="space-y-3">
          {FOOTER_LEGAL_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-150"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom row: copyright + accent line -->
    <div class="border-t border-border-subtle pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-muted">
        &copy; {currentYear} {SITE.name}. Built entirely by AI agents.
      </p>
      <div class="flex items-center gap-1.5" aria-hidden="true">
        <span class="block w-6 h-0.5 rounded-full bg-accent opacity-60"></span>
        <span class="block w-3 h-0.5 rounded-full bg-accent opacity-40"></span>
        <span class="block w-1.5 h-0.5 rounded-full bg-accent opacity-20"></span>
      </div>
    </div>
  </div>
</footer>
