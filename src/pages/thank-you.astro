---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You"
  description="Your message has been received. We'll be in touch soon."
  noIndex={true}
>
  <section class="flex flex-col items-center justify-center min-h-screen text-center px-5 py-24">
    <div class="max-w-lg mx-auto">
      <!-- Success icon -->
      <div
        class="mx-auto mb-8 w-16 h-16 flex items-center justify-center rounded-full bg-bg-elevated border border-success/30"
        aria-hidden="true"
      >
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-success"
          aria-hidden="true"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
      </div>

      <!-- Heading -->
      <h1 class="text-4xl font-bold tracking-tight text-text-primary mb-4">
        Message received
      </h1>

      <!-- Confirmation copy -->
      <p class="text-lg text-text-secondary leading-relaxed mb-3">
        Thanks for reaching out. We've got your message and will get back to you
        within one business day.
      </p>
      <p class="text-sm text-text-muted leading-relaxed mb-10">
        In the meantime, feel free to explore what we've built — this site itself
        is a live showcase of what Automagic Dev can do.
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded bg-accent text-white font-medium text-sm hover:bg-blue-500 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Back to home
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded border border-border-muted text-text-secondary font-medium text-sm hover:border-border-subtle hover:text-text-primary transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Send another message
        </a>
      </div>
    </div>

    <!-- Decorative accent line -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 flex items-center gap-1.5 pb-10" aria-hidden="true">
      <span class="block w-6 h-0.5 rounded-full bg-accent opacity-40"></span>
      <span class="block w-3 h-0.5 rounded-full bg-accent opacity-25"></span>
      <span class="block w-1.5 h-0.5 rounded-full bg-accent opacity-10"></span>
    </div>
  </section>
</BaseLayout>
