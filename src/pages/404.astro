---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Head back home or explore what Automagic Dev has built."
  noIndex={true}
>
  <section class="relative flex flex-col items-center justify-center min-h-screen text-center px-5 py-24">
    <div class="max-w-lg mx-auto">
      <!-- 404 accent number -->
      <div
        class="mb-6 font-black text-[7rem] leading-none tracking-tight text-transparent select-none"
        style="background: linear-gradient(135deg, #3B82F6 0%, #1d4ed8 100%); -webkit-background-clip: text; background-clip: text;"
        aria-hidden="true"
      >
        404
      </div>

      <!-- Heading -->
      <h1 class="text-4xl font-bold tracking-tight text-text-primary mb-4">
        Page not found
      </h1>

      <!-- Subtext -->
      <p class="text-lg text-text-secondary leading-relaxed mb-3">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <p class="text-sm text-text-muted leading-relaxed mb-10">
        If you think something is broken, feel free to reach out — we build and
        maintain this site ourselves.
      </p>

      <!-- Navigation links -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded bg-accent text-white font-medium text-sm hover:bg-blue-500 transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Back to home
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 rounded border border-border-muted text-text-secondary font-medium text-sm hover:border-border-subtle hover:text-text-primary transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Contact us
        </a>
      </div>

      <!-- Quick nav links -->
      <nav aria-label="Quick navigation" class="flex items-center justify-center gap-6">
        <a
          href="/#services"
          class="text-sm text-text-muted hover:text-text-secondary transition-colors duration-150"
        >
          Services
        </a>
        <a
          href="/#process"
          class="text-sm text-text-muted hover:text-text-secondary transition-colors duration-150"
        >
          Process
        </a>
        <a
          href="/about"
          class="text-sm text-text-muted hover:text-text-secondary transition-colors duration-150"
        >
          About
        </a>
      </nav>
    </div>

    <!-- Decorative accent line -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 flex items-center gap-1.5 pb-10" aria-hidden="true">
      <span class="block w-6 h-0.5 rounded-full bg-accent opacity-40"></span>
      <span class="block w-3 h-0.5 rounded-full bg-accent opacity-25"></span>
      <span class="block w-1.5 h-0.5 rounded-full bg-accent opacity-10"></span>
    </div>
  </section>
</BaseLayout>
